DATABASE_URL="mysql://your_db_user:your_user_password@server:port/pc_feature_board"
JWT_SECRET="super_secret_key"
JWT_EXPIRES_IN="7d"
PORT=8080
CORS_ORIGIN="http://localhost:5173"  # your frontend host

# Optional: link in "new feature" emails (e.g. https://features.example.com)
APP_PUBLIC_URL="http://localhost:5173"

# Mailgun (new feature notifications to all active admins)
MAILGUN_API_KEY=""
MAILGUN_DOMAIN="mg.example.com"
MAILGUN_FROM="Feature Board <noreply@mg.example.com>"

# Daily "Your Scoring Todo" digest: run on a schedule (e.g. DigitalOcean App Platform Job), not inside the web process:
#   cd backend && npm run send-daily-scoring-reminders
# Requires MAILGUN_* and APP_PUBLIC_URL (same as other board emails). Schedules are usually UTC on App Platform.

# DigitalOcean Spaces (S3-compatible)
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_REGION="nyc3"
DO_SPACES_BUCKET="your-bucket"
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
# Optional CDN origin for presigned URLs (defaults to bucket endpoint)
# DO_SPACES_CDN_URL="https://your-bucket.nyc3.cdn.digitaloceanspaces.com"
